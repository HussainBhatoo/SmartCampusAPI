package com.mycompany.smartcampus.resources;

import jakarta.ws.rs.core.MediaType;
import com.mycompany.smartcampus.GenericDAO;
import com.mycompany.smartcampus.Sensor;
import jakarta.ws.rs.Consumes;
import jakarta.ws.rs.Path;
import jakarta.ws.rs.GET;
import jakarta.ws.rs.POST;
import jakarta.ws.rs.Produces;
import jakarta.ws.rs.QueryParam; 
import jakarta.ws.rs.core.Response;
import java.util.ArrayList;
import java.util.stream.Collectors;
import java.util.List;
/**
/**
 *
 * @author bh603
 */

@Path("/sensors")
public class SensorResource {

    private static final GenericDAO<Sensor> sensorDAO = new GenericDAO<>(new ArrayList<>());
    private static final GenericDAO<com.mycompany.smartcampus.resources.Room> roomDAO = RoomResource.roomDAO;
    
    
    @GET
    @Produces(MediaType.APPLICATION_JSON)
    public Response getSensors(@QueryParam("type") String type) {
        List<Sensor> sensors = sensorDAO.getAll();
        
        if(type == null || type.isEmpty()) {
            return Response.ok(sensors).build();
        } else  {
            List<Sensor> filteredlist = sensors.stream()
                .filter(sensor -> sensor.getType().equalsIgnoreCase(type))
                .collect(Collectors.toList());
        
            return Response.ok(filteredlist).build();
        }
        
    }
    
    @POST
    @Consumes(MediaType.APPLICATION_JSON)
    @Produces(MediaType.APPLICATION_JSON)
    public Response addSensor(Sensor sensor) {
      if (roomDAO.getById(sensor.getRoomId()) == null) {
          return Response.status (Response.Status.NOT_FOUND)
                  .entity(sensor.getRoomId() + "Error: Room Id doesn't exist" )
                  .build();
      
              
     }
     sensorDAO.add(sensor);
     return Response.status(Response.Status.CREATED)
             .entity(sensor)
             .build();
     
    
    }

 
    

}





