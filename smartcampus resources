package com.mycompany.smartcampus.resources;

import com.mycompany.smartcampus.GenericDAO;
import com.mycompany.smartcampus.Sensor;
import com.mycompany.smartcampus.SensorReading;
import com.mycompany.smartcampus.exception.LinkedResourceNotFoundException;
import jakarta.ws.rs.Consumes;
import jakarta.ws.rs.GET;
import jakarta.ws.rs.POST;
import jakarta.ws.rs.Path;
import jakarta.ws.rs.PathParam;
import jakarta.ws.rs.Produces;
import jakarta.ws.rs.core.MediaType;
import jakarta.ws.rs.core.Response;
import java.util.ArrayList;
import java.util.List;
import java.util.stream.Collectors;

/**
 *
 * @author bh603
 */
@Path("/sensors/{sensorId}/readings")
public class SensorReadingResource {
    private static final GenericDAO<SensorReading> sensorReadingDAO = new GenericDAO<>(new ArrayList<>());
    private static final GenericDAO<Sensor> sensorDAO = new GenericDAO<>(new ArrayList<>());
    
    @PathParam("sensorId")
    private String sensorId;
   
            
    public SensorReadingResource() {}

    
     
    
    @GET
    @Produces(MediaType.APPLICATION_JSON)
    public Response getReadings(@PathParam("sensorId") String sensorId) {
        List<SensorReading> filteredList = sensorReadingDAO.getAll().stream()   
            .filter(reading -> reading.getSensorId() != null && reading.getSensorId().equals(sensorId))
            .collect(Collectors.toList());
            
            if (filteredList == null) {
                throw new LinkedResourceNotFoundException("No readings found for this sensor" + sensorId);
            }
            return Response.ok(filteredList).build();
    }
    
    
   
    @POST
    @Consumes(MediaType.APPLICATION_JSON)
    public Response addReading(@PathParam("sensorId") String sensorId, SensorReading newReading) {
        
        newReading.setSensorId(sensorId);
        
        Sensor parentSensor = sensorDAO.getById(sensorId);
        
        if (parentSensor == null) {
            //throw new LinkedResourceNotFoundException("Sensor" + this.sensorId + "was not found");
            return Response.status(Response.Status.NOT_FOUND)
                .entity("Error: Sensor " + sensorId + "was not found")
                .build();
        }
               
        if ("MAINTENANCE".equalsIgnoreCase(parentSensor.getStatus())) {
            //throw new SensorUnavailableException(this.sensorId + " sensor is under maintenance" );
            return Response.status(Response.Status.FORBIDDEN)
                    .entity("Error: Sensor is currently under maintenance")
                    .build();
            //parentSensor.setCurrentValue(newReading.getValue());
        }
        
        sensorReadingDAO.add(newReading); 
        return Response.status(201).entity(newReading).build();
    }
    
    
    
     
    
    
    

      
    
    
    
    
    
}



